# Variáveis de ambiente - Configure com seus dados
NODE_ENV=
BACKEND_URL=https://seu-dominio-backend.com
FRONTEND_URL=https://seu-dominio-frontend.com
PROXY_PORT=443
PORT=4000

# Banco de dados
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=5432
DB_USER=nome_usuario
DB_PASS=sua_senha_aqui
DB_NAME=nome_banco

# JWT
JWT_SECRET=seu_jwt_secret_aqui
JWT_REFRESH_SECRET=seu_refresh_secret_aqui

# Redis
REDIS_URI=redis://:senha_redis@127.0.0.1:5000
REDIS_OPT_LIMITER_MAX=1
REGIS_OPT_LIMITER_DURATION=3000

# Limites
USER_LIMIT=10
CONNECTIONS_LIMIT=10
CLOSED_SEND_BY_ME=true

# Google OAuth (configure com suas credenciais)
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GMAIL_REFRESH_TOKEN=seu_refresh_token_aqui
