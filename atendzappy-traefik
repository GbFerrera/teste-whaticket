system_create_user() {
  print_banner
  log_info "Criando usuário deploy..."
  sleep 2

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  
  if id "deploy" &>/dev/null; then
    echo "Usuário deploy já existe"
  else
    useradd -m -s /bin/bash deploy
    echo "deploy:${DEPLOY_PASSWORD}" | chpasswd
    usermod -aG sudo deploy
    echo "Usuário deploy criado com sucesso"
  fi
  
  # Adicionar ao grupo docker se Docker estiver instalado
  if command -v docker &>/dev/null; then
    usermod -aG docker deploy
    echo "Usuário deploy adicionado ao grupo docker"
  fi
  
  # Criar diretórios necessários para deploy
  mkdir -p /home/deploy/.pm2 2>/dev/null || true
  mkdir -p /home/deploy/.npm 2>/dev/null || true
  mkdir -p /home/deploy/.cache 2>/dev/null || true
  mkdir -p /home/deploy/.local/bin 2>/dev/null || true
  chown -R deploy:deploy /home/deploy
  chmod -R 755 /home/deploy/.pm2
  chmod -R 755 /home/deploy/.npm
  
  # Adicionar deploy ao sudoers sem senha para pm2
  echo "deploy ALL=(ALL) NOPASSWD: /usr/bin/pm2, /usr/lib/node_modules/pm2/bin/pm2" > /etc/sudoers.d/deploy-pm2
  chmod 440 /etc/sudoers.d/deploy-pm2
EOF

  log_success "Usuário deploy configurado"
  sleep 2
}

