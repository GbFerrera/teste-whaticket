[http.routers]
  [http.routers.atendzappy-backend-${empresa_dominio}]
    entryPoints = ["websecure"]
    rule = "Host(\`${backend_domain}\`)"
    service = "atendzappy-backend-${empresa_dominio}"
    [http.routers.atendzappy-backend-${empresa_dominio}.tls]
      certResolver = "letsencrypt"

  [http.routers.atendzappy-frontend-${empresa_dominio}]
    entryPoints = ["websecure"]
    rule = "Host(\`${frontend_domain}\`)"
    service = "atendzappy-frontend-${empresa_dominio}"
    [http.routers.atendzappy-frontend-${empresa_dominio}.tls]
      certResolver = "letsencrypt"

[http.services]
  [http.services.atendzappy-backend-${empresa_dominio}]
    [http.services.atendzappy-backend-${empresa_dominio}.loadBalancer]
      [[http.services.atendzappy-backend-${empresa_dominio}.loadBalancer.servers]]
        url = "http://127.0.0.1:${alter_backend_port}"

  [http.services.atendzappy-frontend-${empresa_dominio}]
    [http.services.atendzappy-frontend-${empresa_dominio}.loadBalancer]
      [[http.services.atendzappy-frontend-${empresa_dominio}.loadBalancer.servers]]
        url = "http://127.0.0.1:${alter_frontend_port}"
DYNAMICEOF
EOF

  # Reiniciar Traefik para aplicar novas configurações
  sudo docker restart traefik 2>/dev/null || log_warning "Traefik container não encontrado"

  log_success "Domínios alterados para ${empresa_dominio}"
  sleep 2
}

# ============================================================================
# MENU PRINCIPAL
# ============================================================================

inquiry_options() {
  print_banner
  printf " Bem-vindo ao AtendZappy SaaS com Traefik - Selecione uma opção:${GRAY_LIGHT}\n\n"
  printf "   [1] Instalar AtendZappy SaaS\n"
  printf "   [2] Deletar AtendZappy SaaS\n"
  printf "   [3] Bloquear AtendZappy SaaS\n"
  printf "   [4] Desbloquear AtendZappy SaaS\n"
  printf "   [5] Alterar domínio AtendZappy SaaS\n"
  printf "\n"
  read -p "> " option

  case "${option}" in
    1) 
      get_instancia_add
      get_max_whats
      get_max_user
      get_frontend_url
      get_backend_url
      get_frontend_port
      get_backend_port
      get_redis_port
      generate_redis_password
      ;;
    2) 
      get_empresa_delete
      deletar_tudo
      exit 0
      ;;
    3) 
      get_empresa_bloquear
      configurar_bloqueio
      exit 0
      ;;
    4) 
      get_empresa_desbloquear
      configurar_desbloqueio
      exit 0
      ;;
    5) 
      get_empresa_dominio
      get_alter_frontend_url
      get_alter_backend_url
      get_alter_frontend_port
      get_alter_backend_port
      configurar_dominio
      exit 0
      ;;
    *) 
      log_error "Opção inválida"
      exit 1
      ;;
  esac
}

# ============================================================================
# FLUXO PRINCIPAL DE INSTALAÇÃO
# ============================================================================

main() {
  # Reset shell colors
  tput init

  # Criar arquivo de configuração se não existir
  if [[ ! -e "${PROJECT_ROOT}"/config ]]; then
    cat <<EOF > "${PROJECT_ROOT}"/config
deploy_password=${DEPLOY_PASSWORD}
db_pass=${DB_PASS}
EOF
    sudo chown root:root "${PROJECT_ROOT}"/config 2>/dev/null || true
    sudo chmod 700 "${PROJECT_ROOT}"/config 2>/dev/null || true
  fi

  # Menu interativo
  inquiry_options

  # Instalação das dependências do sistema
  system_configure_noninteractive
  system_update
  system_node_install
  system_pm2_install
  system_fix_permissions
  system_docker_install
  system_snapd_install
  system_traefik_install
  system_certbot_install

  # Configuração do usuário
  system_create_user

  # Backend
  system_create_folder
  system_mv_folder
  system_unzip_atendzappy
  copy_database_file
  backend_set_env
  backend_redis_create
  backend_node_dependencies
  backend_node_build
  backend_db_migrate
  backend_db_seed
  backend_start_pm2
  backend_traefik_setup

  # Frontend
  frontend_set_env
  frontend_node_dependencies
  frontend_node_build
  frontend_start_pm2
  frontend_traefik_setup

  # Configuração final
  system_traefik_start
  system_traefik_restart

  # Mensagem final
  print_banner
  
  # Verificar se houve erros
  if [ ${#INSTALLATION_ERRORS[@]} -eq 0 ]; then
    printf "${GREEN}"
    printf "========================================================\n"
    printf "           INSTALAÇÃO CONCLUÍDA COM SUCESSO!          \n"
    printf "========================================================\n"
    printf "${NC}\n"
  else
    printf "${YELLOW}"
    printf "========================================================\n"
    printf "         INSTALAÇÃO CONCLUÍDA COM ALGUNS ERROS         \n"
    printf "========================================================\n"
    printf "${NC}\n"
  fi

  printf "${WHITE} Informações da Instalação:${NC}\n\n"
  printf "   ${CYAN_LIGHT}Instância:${NC} ${instancia_add}\n"
  printf "   ${CYAN_LIGHT}Frontend:${NC} ${frontend_url}\n"
  printf "   ${CYAN_LIGHT}Backend:${NC} ${backend_url}\n"
  printf "   ${CYAN_LIGHT}Porta Frontend:${NC} ${frontend_port}\n"
  printf "   ${CYAN_LIGHT}Porta Backend:${NC} ${backend_port}\n"
  printf "   ${CYAN_LIGHT}Porta Redis:${NC} ${redis_port}\n"
  printf "   ${CYAN_LIGHT}Usuário Deploy:${NC} deploy\n"
  printf "   ${CYAN_LIGHT}Senha Deploy:${NC} ${DEPLOY_PASSWORD}\n"
  printf "   ${CYAN_LIGHT}Senha Redis:${NC} ${redis_pass}\n"
  printf "   ${CYAN_LIGHT}Senha Banco:${NC} ${DB_PASS}\n"
  printf "   ${CYAN_LIGHT}Max WhatsApp:${NC} ${max_whats}\n"
  printf "   ${CYAN_LIGHT}Max Usuários:${NC} ${max_user}\n"
  printf "\n"

  # Informações do Docker
  printf "${WHITE} Status do Docker:${NC}\n\n"
  if command -v docker &> /dev/null; then
    printf "   ${CYAN_LIGHT}Docker:${NC} $(docker --version 2>/dev/null || echo 'Não instalado')\n"
    printf "   ${CYAN_LIGHT}Containers ativos:${NC}\n"
    docker ps --format "      - {{.Names}}: {{.Status}}" 2>/dev/null || printf "      Nenhum container ativo\n"
    printf "\n"
    printf "   ${CYAN_LIGHT}Container Redis:${NC}\n"
    docker ps -a --filter "name=redis-${instancia_add}" --format "      Status: {{.Status}}" 2>/dev/null || printf "      Não encontrado\n"
    printf "   ${CYAN_LIGHT}Container Traefik:${NC}\n"
    docker ps -a --filter "name=traefik" --format "      Status: {{.Status}}" 2>/dev/null || printf "      Não encontrado\n"
    printf "\n"
    printf "   ${CYAN_LIGHT}Dashboard Traefik:${NC} http://$(hostname -I | awk '{print $1}'):8080/dashboard/\n"
  else
    printf "   ${RED}Docker não instalado${NC}\n"
  fi
  printf "\n"

  # Status do PM2
  printf "${WHITE} Status do PM2:${NC}\n\n"
  if command -v pm2 &> /dev/null; then
    pm2 list 2>/dev/null | head -20 || printf "   Nenhum processo PM2\n"
  else
    printf "   ${RED}PM2 não instalado${NC}\n"
  fi
  printf "\n"

  # Exibir warnings se houver
  if [ ${#INSTALLATION_WARNINGS[@]} -gt 0 ]; then
    printf "${YELLOW} AVISOS DURANTE A INSTALAÇÃO (${#INSTALLATION_WARNINGS[@]}):${NC}\n\n"
    for warning in "${INSTALLATION_WARNINGS[@]}"; do
      printf "   ${YELLOW}  ${warning}${NC}\n"
    done
    printf "\n"
  fi

  # Exibir erros se houver
  if [ ${#INSTALLATION_ERRORS[@]} -gt 0 ]; then
    printf "${RED} ERROS DURANTE A INSTALAÇÃO (${#INSTALLATION_ERRORS[@]}):${NC}\n\n"
    for error in "${INSTALLATION_ERRORS[@]}"; do
      printf "   ${RED}  ${error}${NC}\n"
    done
    printf "\n"
    printf "${YELLOW} DICAS PARA RESOLVER:${NC}\n"
    printf "   Verifique se existe atendzappy.zip ou as pastas backend/frontend no diretório do script\n"
    printf "   Execute: ls -la /home/deploy/${instancia_add}/\n"
    printf "   Verifique logs: sudo pm2 logs\n"
    printf "   Verifique Docker: sudo docker ps -a\n"
    printf "   Verifique Traefik: sudo docker logs traefik\n"
    printf "\n"
  fi

  printf "${YELLOW} IMPORTANTE: Anote essas informações em local seguro!${NC}\n\n"
  printf "${GREEN} Acesse: ${frontend_url}${NC}\n"
  printf "${GREEN} Login padrão: admin@admin.com${NC}\n"
  printf "${GREEN} Senha padrão: adminpro${NC}\n\n"

  # Salvar informações em arquivo
  cat > /home/deploy/${instancia_add}/INSTALACAO_INFO.txt << INFOEOF
========================================
INFORMAÇÕES DA INSTALAÇÃO - ${instancia_add}
Data: $(date)
========================================

ACESSOS:
- Frontend: ${frontend_url}
- Backend: ${backend_url}
- Login: admin@admin.com
- Senha: adminpro
- Dashboard Traefik: http://$(hostname -I | awk '{print $1}'):8080/dashboard/

PORTAS:
- Frontend: ${frontend_port}
- Backend: ${backend_port}
- Redis: ${redis_port}

CREDENCIAIS:
- Usuário Deploy: deploy
- Senha Deploy: ${DEPLOY_PASSWORD}
- Senha Redis: ${redis_pass}
- Senha Banco: ${DB_PASS}

LIMITES:
- Max WhatsApp: ${max_whats}
- Max Usuários: ${max_user}

COMANDOS ÚTEIS:
- Ver status: sudo pm2 status
- Ver logs backend: sudo pm2 logs ${instancia_add}-backend
- Ver logs frontend: sudo pm2 logs ${instancia_add}-frontend
- Reiniciar: sudo pm2 restart all
- Ver Docker: sudo docker ps
- Ver logs Traefik: sudo docker logs traefik
- Reiniciar Traefik: sudo docker restart traefik

INFOEOF

  sudo chown deploy:deploy /home/deploy/${instancia_add}/INSTALACAO_INFO.txt 2>/dev/null
  printf "${GREEN} Informações salvas em: /home/deploy/${instancia_add}/INSTALACAO_INFO.txt${NC}\n\n"
}

# Executar instalação
main "$@"
