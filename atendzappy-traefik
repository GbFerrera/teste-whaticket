system_traefik_start() {
  print_banner
  log_info "Iniciando Traefik..."
  sleep 2

  backend_domain=$(echo "${backend_url}" | sed 's|https://||')
  frontend_domain=$(echo "${frontend_url}" | sed 's|https://||')

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  
  # Gerar configuração estática do Traefik
  cat > /etc/traefik/traefik.toml << 'TRAefikEOF'
[global]
  checkNewVersion = true
  sendAnonymousUsage = false

[entryPoints]
  [entryPoints.web]
    address = ":80"
    [entryPoints.web.http.redirections]
      [entryPoints.web.http.redirections.entryPoint]
        to = "websecure"
        scheme = "https"
        permanent = true

  [entryPoints.websecure]
    address = ":443"

[providers]
  [providers.docker]
    exposedByDefault = false
    network = "traefik-network"

  [providers.file]
    directory = "/etc/traefik/dynamic-conf"
    watch = true

[certificatesResolvers]
  [certificatesResolvers.letsencrypt]
    [certificatesResolvers.letsencrypt.acme]
      email = "${DEPLOY_EMAIL}"
      storage = "/etc/traefik/acme.json"
      [certificatesResolvers.letsencrypt.acme.httpChallenge]
        entryPoint = "web"

[api]
  dashboard = true
  insecure = true

[log]
  level = "INFO"

[accessLog]
TRAefikEOF

  # Gerar configuração dinâmica para esta instância
  cat > /etc/traefik/dynamic-conf/${instancia_add}-config.toml << DYNAMICEOF
[http.routers]
  [http.routers.atendzappy-backend-${instancia_add}]
    entryPoints = ["websecure"]
    rule = "Host(\`${backend_domain}\`)"
    service = "atendzappy-backend-${instancia_add}"
    [http.routers.atendzappy-backend-${instancia_add}.tls]
      certResolver = "letsencrypt"

  [http.routers.atendzappy-frontend-${instancia_add}]
    entryPoints = ["websecure"]
    rule = "Host(\`${frontend_domain}\`)"
    service = "atendzappy-frontend-${instancia_add}"
    [http.routers.atendzappy-frontend-${instancia_add}.tls]
      certResolver = "letsencrypt"

[http.services]
  [http.services.atendzappy-backend-${instancia_add}]
    [http.services.atendzappy-backend-${instancia_add}.loadBalancer]
      [[http.services.atendzappy-backend-${instancia_add}.loadBalancer.servers]]
        url = "http://127.0.0.1:${backend_port}"

  [http.services.atendzappy-frontend-${instancia_add}]
    [http.services.atendzappy-frontend-${instancia_add}.loadBalancer]
      [[http.services.atendzappy-frontend-${instancia_add}.loadBalancer.servers]]
        url = "http://127.0.0.1:${frontend_port}"
DYNAMICEOF

  # Iniciar Traefik
  docker run -d \\
    --name traefik \\
    --restart always \\
    -p 80:80 \\
    -p 443:443 \\
    -p 8080:8080 \\
    --network traefik-network \\
    -v /var/run/docker.sock:/var/run/docker.sock:ro \\
    -v /etc/traefik:/etc/traefik \\
    -v /var/log/traefik:/var/log/traefik \\
    traefik:v2.10 --configfile=/etc/traefik/traefik.toml
EOF

  log_success "Traefik iniciado"
  sleep 2
}

