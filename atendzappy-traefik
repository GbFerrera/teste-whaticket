  sudo su - root <<'EOF'
  # ============================================
  # PERMISSÕES DO NODE.JS E NPM
  # ============================================
  chmod -R 755 /usr/lib/node_modules 2>/dev/null || true
  chmod -R 755 /usr/local/lib/node_modules 2>/dev/null || true
  chmod -R 755 /usr/share/npm 2>/dev/null || true
  
  # Binários principais
  chmod +x /usr/bin/node 2>/dev/null || true
  chmod +x /usr/bin/npm 2>/dev/null || true
  chmod +x /usr/bin/npx 2>/dev/null || true
  chmod +x /usr/bin/corepack 2>/dev/null || true
  
  # ============================================
  # PERMISSÕES DO TYPESCRIPT
  # ============================================
  chmod +x /usr/bin/tsc 2>/dev/null || true
  chmod +x /usr/bin/tsserver 2>/dev/null || true
  chmod -R 755 /usr/lib/node_modules/typescript 2>/dev/null || true
  chmod +x /usr/lib/node_modules/typescript/bin/tsc 2>/dev/null || true
  chmod +x /usr/lib/node_modules/typescript/bin/tsserver 2>/dev/null || true
  ln -sf /usr/lib/node_modules/typescript/bin/tsc /usr/bin/tsc 2>/dev/null || true
  ln -sf /usr/lib/node_modules/typescript/bin/tsserver /usr/bin/tsserver 2>/dev/null || true
  
  # ============================================
  # PERMISSÕES DO PM2
  # ============================================
  chmod -R 755 /usr/lib/node_modules/pm2 2>/dev/null || true
  chmod +x /usr/lib/node_modules/pm2/bin/pm2 2>/dev/null || true
  chmod +x /usr/lib/node_modules/pm2/bin/pm2-dev 2>/dev/null || true
  chmod +x /usr/lib/node_modules/pm2/bin/pm2-docker 2>/dev/null || true
  chmod +x /usr/lib/node_modules/pm2/bin/pm2-runtime 2>/dev/null || true
  ln -sf /usr/lib/node_modules/pm2/bin/pm2 /usr/bin/pm2 2>/dev/null || true
  ln -sf /usr/lib/node_modules/pm2/bin/pm2-dev /usr/bin/pm2-dev 2>/dev/null || true
  ln -sf /usr/lib/node_modules/pm2/bin/pm2-docker /usr/bin/pm2-docker 2>/dev/null || true
  ln -sf /usr/lib/node_modules/pm2/bin/pm2-runtime /usr/bin/pm2-runtime 2>/dev/null || true
  chmod +x /usr/bin/pm2 2>/dev/null || true
  chmod +x /usr/bin/pm2-dev 2>/dev/null || true
  chmod +x /usr/bin/pm2-docker 2>/dev/null || true
  chmod +x /usr/bin/pm2-runtime 2>/dev/null || true
  
  # Diretório PM2 do usuário root
  mkdir -p /root/.pm2 2>/dev/null || true
  chmod -R 755 /root/.pm2 2>/dev/null || true
  
  # ============================================
  # PERMISSÕES GLOBAIS DE BINÁRIOS
  # ============================================
  chmod -R 755 /usr/local/bin 2>/dev/null || true
  
  # Corrigir todos os binários em node_modules
  find /usr/lib/node_modules -type f -name "*.js" -exec chmod +x {} \; 2>/dev/null || true
  find /usr/lib/node_modules/*/bin -type f -exec chmod +x {} \; 2>/dev/null || true
  find /usr/local/lib/node_modules -type f -name "*.js" -exec chmod +x {} \; 2>/dev/null || true
  find /usr/local/lib/node_modules/*/bin -type f -exec chmod +x {} \; 2>/dev/null || true
  
  # ============================================
  # PERMISSÕES DO USUÁRIO DEPLOY
  # ============================================
