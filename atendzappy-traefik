# Substituído por Traefik
system_traefik_install() {
  print_banner
  log_info "Instalando e configurando Traefik..."
  sleep 2

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive
  export NEEDRESTART_MODE=a
  export NEEDRESTART_SUSPEND=1
  
  # Criar diretórios do Traefik
  mkdir -p /etc/traefik/dynamic-conf
  mkdir -p /var/log/traefik
  
  # Criar rede Docker para Traefik
  docker network create traefik-network 2>/dev/null || echo "Rede já existe"
  
  # Criar arquivo ACME para certificados SSL
  touch /etc/traefik/acme.json
  chmod 600 /etc/traefik/acme.json
  
  # Parar e remover nginx se estiver instalado
  systemctl stop nginx 2>/dev/null || true
  systemctl disable nginx 2>/dev/null || true
  apt-get remove -y nginx nginx-common 2>/dev/null || true
  apt-get autoremove -y 2>/dev/null || true
EOF

  log_success "Traefik configurado"
  sleep 2
}

