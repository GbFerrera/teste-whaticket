backend_redis_create() {
  print_banner
  log_info "Criando Redis e PostgreSQL em Docker..."
  sleep 2

  if [ -z "${redis_port}" ] || [ -z "${redis_pass}" ] || [ -z "${instancia_add}" ]; then
    log_warning "Variáveis Redis não definidas, usando padrões..."
    redis_port=${redis_port:-5000}
    redis_pass=${redis_pass:-"RedisPass123"}
  fi

  # Gerar senha PostgreSQL única para esta instância
  postgres_pass="PG$(openssl rand -base64 12 | tr -d "=+/" | cut -c1-16)${instancia_add}"
  export postgres_pass

  sudo su - root <<EOF
  usermod -aG docker deploy

  # Criar rede Docker para a instância se não existir
  docker network create ${instancia_add}-network 2>/dev/null || echo "Rede já existe"

  # PostgreSQL em Docker
  docker run --name postgres-${instancia_add} \
    -e POSTGRES_DB=${instancia_add} \
    -e POSTGRES_USER=${instancia_add} \
    -e POSTGRES_PASSWORD=${postgres_pass} \
    -p 5432:5432 \
    --restart always \
    --network ${instancia_add}-network \
    -v /home/deploy/${instancia_add}/postgres-data:/var/lib/postgresql/data \
    --detach postgres:15

  # Redis na mesma rede
  docker run --name redis-${instancia_add} \
    -p ${redis_port}:6379 \
    --restart always \
    --network ${instancia_add}-network \
    --detach redis \
    redis-server --requirepass ${redis_pass}
EOF

  sleep 10

  # Verificar se os containers estão rodando
  if ! docker ps | grep -q "postgres-${instancia_add}"; then
    log_warning "PostgreSQL pode não ter iniciado corretamente, verificando logs..."
    docker logs "postgres-${instancia_add}" 2>/dev/null || true
  fi

  if ! docker ps | grep -q "redis-${instancia_add}"; then
    log_warning "Redis pode não ter iniciado corretamente, verificando logs..."
    docker logs "redis-${instancia_add}" 2>/dev/null || true
  fi

  log_success "PostgreSQL rodando na porta 5432"
  log_success "Redis rodando na porta ${redis_port}"
  log_info "Senha PostgreSQL: ${postgres_pass}"
  
  # Criar arquivo com senhas para referência
  sudo su - deploy <<EOF
  cat > /home/deploy/${instancia_add}/db_credentials.txt << CREDFILE
PostgreSQL Host: localhost
PostgreSQL Port: 5432
PostgreSQL Database: ${instancia_add}
PostgreSQL User: ${instancia_add}
PostgreSQL Password: ${postgres_pass}

Redis Host: localhost
Redis Port: ${redis_port}
Redis Password: ${redis_pass}
CREDFILE
EOF

  sleep 2
}

