  printf "   ${CYAN_LIGHT}Max Usuários:${NC}   ${max_user}\n"
  printf "\n"

  printf "${WHITE}🔀 Status do Traefik:${NC}\n\n"
  if docker ps | grep -q "traefik"; then
    printf "   ${GREEN}✅ Traefik em execução${NC}\n"
    printf "   ${CYAN_LIGHT}Rota backend criada:${NC}  /etc/traefik/dynamic/${instancia_add}.yml\n"
    printf "   ${CYAN_LIGHT}SSL:${NC}                  Let's Encrypt automático\n"
    printf "   ${CYAN_LIGHT}HTTP→HTTPS:${NC}           Redirecionamento automático\n"
  else
    printf "   ${RED}  Traefik NÃO está em execução${NC}\n"
    printf "   Execute: cd /etc/traefik && docker compose up -d\n"
  fi
  printf "\n"

  printf "${WHITE}  Status dos Containers Docker:${NC}\n\n"
  if docker ps | grep -q "postgres-${instancia_add}"; then
    printf "   ${GREEN}  PostgreSQL rodando${NC}\n"
  else
    printf "   ${RED}  PostgreSQL NÃO está rodando${NC}\n"
  fi
  
  if docker ps | grep -q "redis-${instancia_add}"; then
    printf "   ${GREEN}  Redis rodando${NC}\n"
  else
    printf "   ${RED}  Redis NÃO está rodando${NC}\n"
  fi
  
  printf "   ${CYAN_LIGHT}Rede Docker:${NC}       ${instancia_add}-network\n"
  printf "   ${CYAN_LIGHT}Dados PostgreSQL:${NC}  /home/deploy/${instancia_add}/postgres-data\n"
  printf "\n"

  printf "${WHITE}  Status do PM2:${NC}\n\n"
  if command -v pm2 &> /dev/null; then
    pm2 list 2>/dev/null | head -20 || printf "   Nenhum processo PM2\n"
  else
    printf "   ${RED}PM2 não instalado${NC}\n"
  fi
  printf "\n"

  if [ ${#INSTALLATION_WARNINGS[@]} -gt 0 ]; then
    printf "${YELLOW}⚠️  AVISOS (${#INSTALLATION_WARNINGS[@]}):${NC}\n\n"
    for warning in "${INSTALLATION_WARNINGS[@]}"; do
      printf "   ${YELLOW}• ${warning}${NC}\n"
    done
    printf "\n"
  fi

  if [ ${#INSTALLATION_ERRORS[@]} -gt 0 ]; then
    printf "${RED}❌ ERROS (${#INSTALLATION_ERRORS[@]}):${NC}\n\n"
    for error in "${INSTALLATION_ERRORS[@]}"; do
      printf "   ${RED}• ${error}${NC}\n"
    done
    printf "\n"
    printf "${YELLOW}💡 DICAS PARA RESOLVER:${NC}\n"
    printf "   • Verifique logs do Traefik: docker logs traefik\n"
    printf "   • Verifique rota: cat /etc/traefik/dynamic/${instancia_add}.yml\n"
    printf "   • Verifique PM2: sudo pm2 logs\n"
    printf "   • Verifique Docker: sudo docker ps -a\n"
    printf "\n"
  fi

  printf "${YELLOW}⚠️  IMPORTANTE: Anote essas informações em local seguro!${NC}\n\n"
  printf "${GREEN}✅ Acesse: ${frontend_url}${NC}\n"
  printf "${GREEN}✅ Login padrão: admin@admin.com${NC}\n"
  printf "${GREEN}✅ Senha padrão: adminpro${NC}\n\n"

  # Salvar informações em arquivo
  cat > /home/deploy/${instancia_add}/INSTALACAO_INFO.txt << INFOEOF
========================================
INFORMAÇÕES DA INSTALAÇÃO - ${instancia_add}
Data: $(date)
========================================

ACESSOS:
- Frontend: ${frontend_url}
- Backend: ${backend_url}
- Login: admin@admin.com
- Senha: adminpro

PORTAS:
- Frontend: ${frontend_port}
- Backend: ${backend_port}
- Redis: ${redis_port}

CREDENCIAIS:
- Usuário Deploy: deploy
- Senha Deploy: ${DEPLOY_PASSWORD}
- Senha Redis: ${redis_pass}
- Senha PostgreSQL: ${postgres_pass}

DOCKER:
- Container PostgreSQL: postgres-${instancia_add}
- Container Redis: redis-${instancia_add}
- Rede Docker: ${instancia_add}-network
- Dados PostgreSQL: /home/deploy/${instancia_add}/postgres-data

LIMITES:
- Max WhatsApp: ${max_whats}
- Max Usuários: ${max_user}

TRAEFIK:
- Config estática: /etc/traefik/traefik.yml
- Rota da instância: /etc/traefik/dynamic/${instancia_add}.yml
- Certificados ACME: /etc/traefik/acme.json
- Logs: /var/log/traefik/

COMANDOS ÚTEIS:
- Ver status PM2: sudo pm2 status
- Logs backend: sudo pm2 logs ${instancia_add}-backend
- Logs frontend: sudo pm2 logs ${instancia_add}-frontend
- Reiniciar tudo: sudo pm2 restart all
- Logs Traefik: docker logs traefik
- Status Docker: sudo docker ps
- Recarregar rota: (automático - Traefik monitora o diretório /etc/traefik/dynamic/)

INFOEOF

  sudo chown deploy:deploy /home/deploy/${instancia_add}/INSTALACAO_INFO.txt 2>/dev/null
  printf "${GREEN}📄 Informações salvas em: /home/deploy/${instancia_add}/INSTALACAO_INFO.txt${NC}\n\n"
}

