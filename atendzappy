# TRAEFIK - substitui completamente Nginx + Certbot
# ============================================================================

system_traefik_install() {
  print_banner
  log_info "Instalando e configurando Traefik v2..."
  sleep 2

  sudo su - root <<EOF
  export DEBIAN_FRONTEND=noninteractive

  # Criar estrutura de diretórios do Traefik
  mkdir -p /etc/traefik/dynamic
  mkdir -p /etc/traefik/certs

  # Arquivo de certificados ACME (Let's Encrypt)
  touch /etc/traefik/acme.json
  chmod 600 /etc/traefik/acme.json

  # Criar rede Docker compartilhada para o Traefik
  docker network create traefik-public 2>/dev/null || echo "Rede traefik-public já existe"

  # Configuração estática principal do Traefik
  cat > /etc/traefik/traefik.yml << 'TRAEFIK_EOF'
# Traefik v2 - Configuração Estática
api:
  dashboard: false    # habilite "true" se quiser o dashboard na porta 8080

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    address: ":443"
    http:
      tls:
        certResolver: letsencrypt

certificatesResolvers:
  letsencrypt:
    acme:
      email: ${DEPLOY_EMAIL}
      storage: /etc/traefik/acme.json
      httpChallenge:
        entryPoint: web

providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    network: traefik-public
  file:
    directory: /etc/traefik/dynamic
    watch: true

log:
  level: INFO
  filePath: /var/log/traefik/traefik.log

accessLog:
  filePath: /var/log/traefik/access.log
TRAEFIK_EOF

  # Criar diretório de logs
  mkdir -p /var/log/traefik

  # Docker Compose do Traefik
  cat > /etc/traefik/docker-compose.yml << 'COMPOSE_EOF'
version: "3.8"

services:
  traefik:
    image: traefik:v2.11
    container_name: traefik
    restart: always
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /etc/traefik/traefik.yml:/etc/traefik/traefik.yml:ro
      - /etc/traefik/dynamic:/etc/traefik/dynamic:ro
      - /etc/traefik/acme.json:/etc/traefik/acme.json
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log/traefik:/var/log/traefik
    networks:
      - traefik-public

networks:
  traefik-public:
    external: true
COMPOSE_EOF

  # Subir o Traefik
  cd /etc/traefik
  docker compose up -d

  sleep 5
  if docker ps | grep -q "traefik"; then
    echo "Traefik iniciado com sucesso"
  else
    echo "AVISO: Traefik pode não ter subido corretamente"
    docker logs traefik 2>/dev/null || true
  fi
EOF

  log_success "Traefik instalado e em execução"
  sleep 2
}

# Configuração dinâmica do Traefik para uma instância (PM2 → Traefik via rota de arquivo)
system_traefik_add_instance() {
  # Parâmetros: $1=instancia, $2=backend_hostname, $3=backend_port, $4=frontend_hostname, $5=frontend_port
  local instancia="$1"
  local back_host="$2"
  local back_port="$3"
  local front_host="$4"
  local front_port="$5"

  print_banner
  log_info "Configurando roteamento Traefik para ${instancia}..."
  sleep 2

  sudo su - root <<EOF
  # Arquivo de roteamento dinâmico Traefik para esta instância
  # Aponta os domínios para os processos PM2 rodando localmente
  cat > /etc/traefik/dynamic/${instancia}.yml << 'DYNEOF'
http:
  routers:
    ${instancia}-backend:
      rule: "Host(\`${back_host}\`)"
      entryPoints:
        - websecure
      service: ${instancia}-backend-svc
      tls:
        certResolver: letsencrypt

    ${instancia}-frontend:
      rule: "Host(\`${front_host}\`)"
      entryPoints:
        - websecure
      service: ${instancia}-frontend-svc
      tls:
        certResolver: letsencrypt

  services:
    ${instancia}-backend-svc:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:${back_port}"
        passHostHeader: true

    ${instancia}-frontend-svc:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:${front_port}"
        passHostHeader: true
DYNEOF

  echo "Rota dinâmica criada: /etc/traefik/dynamic/${instancia}.yml"
EOF

  log_success "Traefik configurado para ${instancia} (backend: ${back_host} → :${back_port} | frontend: ${front_host} → :${front_port})"
  sleep 2
}

# Remove a rota dinâmica de uma instância
system_traefik_remove_instance() {
  local instancia="$1"
  sudo rm -f /etc/traefik/dynamic/${instancia}.yml 2>/dev/null || true
  log_success "Rota Traefik removida para ${instancia}"
}

