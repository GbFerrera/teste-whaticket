system_mv_folder() {
  print_banner
  log_info "Copiando código AtendZappy..."
  sleep 2

  ATENDZAPPY_ZIP=""

  if [ -f "${PROJECT_ROOT}/atendzappy.zip" ]; then
    ATENDZAPPY_ZIP="${PROJECT_ROOT}/atendzappy.zip"
  elif [ -f "$(dirname "${PROJECT_ROOT}")/atendzappy.zip" ]; then
    ATENDZAPPY_ZIP="$(dirname "${PROJECT_ROOT}")/atendzappy.zip"
  elif [ -f "/root/atendzappy.zip" ]; then
    ATENDZAPPY_ZIP="/root/atendzappy.zip"
  elif [ -f "./atendzappy.zip" ]; then
    ATENDZAPPY_ZIP="./atendzappy.zip"
  elif [ -f "/home/deploy/atendzappy.zip" ]; then
    ATENDZAPPY_ZIP="/home/deploy/atendzappy.zip"
  fi

  if [ -n "$ATENDZAPPY_ZIP" ]; then
    log_info "Encontrado: $ATENDZAPPY_ZIP"
    sudo cp "$ATENDZAPPY_ZIP" /home/deploy/${instancia_add}/
    sudo chown deploy:deploy /home/deploy/${instancia_add}/atendzappy.zip

    if [ -f "/home/deploy/${instancia_add}/atendzappy.zip" ]; then
      log_success "Código copiado para /home/deploy/${instancia_add}/"
    else
      register_error "Falha ao copiar atendzappy.zip para /home/deploy/${instancia_add}/"
    fi
    sleep 2
    return
  fi

  CODE_SOURCE=""
  if [ -d "${PROJECT_ROOT}/backend" ] && [ -d "${PROJECT_ROOT}/frontend" ]; then
    CODE_SOURCE="${PROJECT_ROOT}"
  elif [ -d "$(dirname "${PROJECT_ROOT}")/backend" ] && [ -d "$(dirname "${PROJECT_ROOT}")/frontend" ]; then
    CODE_SOURCE="$(dirname "${PROJECT_ROOT}")"
  elif [ -d "./backend" ] && [ -d "./frontend" ]; then
    CODE_SOURCE="."
  elif [ -d "/root/atendzappy/backend" ] && [ -d "/root/atendzappy/frontend" ]; then
    CODE_SOURCE="/root/atendzappy"
  fi

  if [ -z "${CODE_SOURCE}" ]; then
    register_error "Arquivo atendzappy.zip não encontrado e pastas backend/frontend não encontradas!"
    return
  fi

  log_info "Encontrado código em: ${CODE_SOURCE}"
  sudo rm -rf /home/deploy/${instancia_add}/backend /home/deploy/${instancia_add}/frontend 2>/dev/null
  sudo cp -a "${CODE_SOURCE}/backend" "${CODE_SOURCE}/frontend" /home/deploy/${instancia_add}/
  sudo chown -R deploy:deploy /home/deploy/${instancia_add}/backend /home/deploy/${instancia_add}/frontend 2>/dev/null

  if [ -d "/home/deploy/${instancia_add}/backend" ] && [ -d "/home/deploy/${instancia_add}/frontend" ]; then
    log_success "Código copiado (sem zip) para /home/deploy/${instancia_add}/"
  else
    register_error "Falha ao copiar backend/frontend para /home/deploy/${instancia_add}/"
  fi
  sleep 2
}

system_unzip_atendzappy() {
  print_banner
  log_info "Extraindo AtendZappy..."
  sleep 2

  cd /home/deploy/${instancia_add} 2>/dev/null

  if [ ! -f "atendzappy.zip" ]; then
    if [ -d "/home/deploy/${instancia_add}/backend" ] && [ -d "/home/deploy/${instancia_add}/frontend" ]; then
      log_success "AtendZappy pronto (sem zip)"
      sudo chown -R deploy:deploy /home/deploy/${instancia_add} 2>/dev/null
      sleep 2
      return
    fi
    register_error "atendzappy.zip não encontrado e pastas backend/frontend não encontradas em /home/deploy/${instancia_add}/"
    return
  fi

  if [ -d "/home/deploy/${instancia_add}/backend" ] || [ -d "/home/deploy/${instancia_add}/frontend" ]; then
    log_info "Removendo instalação anterior..."
    sudo rm -rf /home/deploy/${instancia_add}/backend /home/deploy/${instancia_add}/frontend 2>/dev/null
  fi

  sudo unzip -o -q atendzappy.zip 2>/dev/null

  if [ $? -ne 0 ]; then
    register_warning "Falha ao extrair silenciosamente, tentando com detalhes..."
    sudo unzip -o atendzappy.zip
  fi

  if [ -d "/home/deploy/${instancia_add}/backend" ] && [ -d "/home/deploy/${instancia_add}/frontend" ]; then
    log_success "AtendZappy extraído com sucesso!"
  else
    register_error "Extração falhou - pastas backend/frontend não encontradas"
    log_warning "Conteúdo do diretório:"
    ls -la /home/deploy/${instancia_add}/ 2>/dev/null || echo "Diretório não existe"
  fi

  sudo chown -R deploy:deploy /home/deploy/${instancia_add} 2>/dev/null
  sleep 2
}

copy_database_file() {
  print_banner
  log_info "Copiando arquivo de banco de dados..."
  sleep 2

  SQL_SOURCE=""
  if [ -f "${PROJECT_ROOT}/atendzappy.sql" ]; then
    SQL_SOURCE="${PROJECT_ROOT}/atendzappy.sql"
  elif [ -f "$(dirname "${PROJECT_ROOT}")/atendzappy.sql" ]; then
    SQL_SOURCE="$(dirname "${PROJECT_ROOT}")/atendzappy.sql"
  elif [ -f "./atendzappy.sql" ]; then
    SQL_SOURCE="./atendzappy.sql"
  elif [ -f "/home/deploy/atendzappy.sql" ]; then
    SQL_SOURCE="/home/deploy/atendzappy.sql"
  elif [ -f "/root/atendzappy.sql" ]; then
    SQL_SOURCE="/root/atendzappy.sql"
  fi

  if [ -z "${SQL_SOURCE}" ]; then
    register_error "Arquivo atendzappy.sql não encontrado!"
    exit 1
  fi

  SQL_PATH="/home/deploy/${instancia_add}/atendzappy.sql"
  sudo cp "${SQL_SOURCE}" "${SQL_PATH}"
  sudo chown deploy:deploy "${SQL_PATH}"

  if [ -f "${SQL_PATH}" ]; then
    log_success "Arquivo atendzappy.sql copiado para /home/deploy/${instancia_add}/"

    if file "${SQL_PATH}" | grep -qi "UTF-16"; then
      log_info "Convertendo atendzappy.sql de UTF-16 para UTF-8..."
      sudo iconv -f UTF-16LE -t UTF-8 "${SQL_PATH}" -o "/home/deploy/${instancia_add}/atendzappy_utf8.sql"
      sudo mv "/home/deploy/${instancia_add}/atendzappy_utf8.sql" "${SQL_PATH}"
      sudo chown deploy:deploy "${SQL_PATH}"
      log_success "Conversão para UTF-8 concluída"
    else
      log_info "atendzappy.sql já está em UTF-8"
    fi
  else
    register_error "Falha ao copiar atendzappy.sql"
  fi

  sleep 2
}

